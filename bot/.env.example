# PolyBot - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ── Trading Mode ──────────────────────────────────────────
# paper = simulated trades (no real money) — START HERE
# live  = real trades (requires wallet + API keys)
TRADING_MODE=paper

# ── Wallet Configuration (required for live trading) ──────
# Your Polygon wallet private key (NEVER share this!)
POLY_PRIVATE_KEY=

# ── Polymarket API Credentials ────────────────────────────
# Get these from: polymarket.com → Profile → Settings → API Keys
# Click "Create API Key" → save key, secret, passphrase
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Optional: Funder address (needed for browser/Magic proxy wallets)
# If you sign in with email/browser, this is your Polymarket proxy address
# POLY_FUNDER_ADDRESS=0x...

# Signature type: 0=EOA (MetaMask/direct wallet), 1=browser proxy, 2=mobile proxy
POLY_SIGNATURE_TYPE=0

# ── Risk Management Overrides ────────────────────────────
# These override settings.json values
# MAX_POSITION_SIZE_USD=3
# MAX_DAILY_LOSS_USD=5
# MAX_OPEN_POSITIONS=3

# ── Strategy Selection ────────────────────────────────────
# Available: straddle, arbitrage, market_making, auto
DEFAULT_STRATEGY=auto
